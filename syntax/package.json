{
  "name": "qpp",
  "displayName": "Q++",
  "description": "Syntax highlighting for Q++ (.q files). Supports backtick interpolation, keywords, types, and builtins.",
  "version": "0.3.0",
  "publisher": "qpp",
  "engines": { "vscode": "^1.60.0" },
  "categories": ["Programming Languages"],
  "contributes": {
    "languages": [{
      "id": "qpp",
      "aliases": ["Q++", "q"],
      "extensions": [".q"],
      "configuration": "./language-configuration.json"
    }],
    "grammars": [{
      "language": "qpp",
      "scopeName": "source.q",
      "path": "./qpp.tmLanguage.json"
    }]
  }
}
