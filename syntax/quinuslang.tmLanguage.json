{
  "$schema": "https://raw.githubusercontent.com/martinring/tmlanguage/master/tmlanguage.json",
  "name": "QuinusLang",
  "scopeName": "source.q",
  "patterns": [
    { "include": "#comments" },
    { "include": "#keywords" },
    { "include": "#types" },
    { "include": "#strings" },
    { "include": "#numbers" },
    { "include": "#operators" },
    { "include": "#functions" }
  ],
  "repository": {
    "comments": {
      "patterns": [
        {
          "name": "comment.line.double-slash.q",
          "match": "//.*$"
        }
      ]
    },
    "keywords": {
      "patterns": [
        {
          "name": "keyword.control.q",
          "match": "\\b(craft|send|make|shift|check|otherwise|loopwhile|foreach|stop|skip|in|for)\\b"
        },
        {
          "name": "keyword.other.q",
          "match": "\\b(eternal|anchor|form|state|fusion|realm|link|mark|reach|hazard|machine|bring|open|import|class|extends|init|new|this|super|impl|implements|try|catch|pub|priv)\\b"
        }
      ]
    },
    "types": {
      "patterns": [
        {
          "name": "storage.type.q",
          "match": "\\b(int|float|bool|str|void|u8|u16|u32|u64|i8|i16|i32|i64|usize|f32|f64)\\b"
        }
      ]
    },
    "strings": {
      "patterns": [
        {
          "name": "string.quoted.double.q",
          "begin": "\"",
          "end": "\"",
          "patterns": [
            {
              "name": "constant.character.escape.q",
              "match": "\\\\."
            }
          ]
        }
      ]
    },
    "numbers": {
      "patterns": [
        {
          "name": "constant.numeric.q",
          "match": "-?\\b[0-9]+(\\.[0-9]+)?([eE][+-]?[0-9]+)?\\b"
        },
        {
          "name": "constant.language.q",
          "match": "\\b(true|false)\\b"
        }
      ]
    },
    "operators": {
      "patterns": [
        {
          "name": "keyword.operator.q",
          "match": "(\\.\\.|->|==|!=|<=|>=|&&|\\|\\||[+\\-*/%=<>!&|])"
        }
      ]
    },
    "functions": {
      "patterns": [
        {
          "name": "support.function.builtin.q",
          "match": "\\b(print|write|writeln|read|len|strlen|panic|assert)\\b"
        },
        {
          "name": "entity.name.function.q",
          "match": "\\b([a-zA-Z_][a-zA-Z0-9_]*)\\s*(?=\\()"
        }
      ]
    }
  }
}
